# Configuración de la base de datos MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=fitness_platform
DB_PORT=3306

# Puerto del servidor
PORT=3000

# Entorno de ejecución
NODE_ENV=development

# JWT Secret (generar con: node -e "require('crypto').randomBytes(32).toString('base64')")
JWT_SECRET=generate_with_node_crypto_randomBytes_32

# OAuth GitHub (obtener en: https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# OAuth Google (obtener en: https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Session Secret (generar con: node -e "require('crypto').randomBytes(64).toString('hex')")
SESSION_SECRET=generate_with_node_crypto_randomBytes_64

# URLs del frontend
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
